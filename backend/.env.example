# Project Configuration
PROJECT_NAME="Core Verification Platform"
VERSION="0.1.0"
ENVIRONMENT="development"

# Database Configuration (PostgreSQL Async)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/core_db"

# Cache Configuration (Redis)
REDIS_URL="redis://localhost:6379/0"

# Security (Change JWT_SECRET in production!)
JWT_SECRET="generate-a-secure-random-string-here"
JWT_ALGORITHM="HS256"

# Telegram Bot Credentials
BOT_TOKEN="your_bot_token_from_bfather"
BOT_WEBHOOK_URL="https://yourdomain.com"

# CORS Configuration (JSON array format for list[str])
ALLOWED_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'

# Logging
LOG_LEVEL="INFO"
